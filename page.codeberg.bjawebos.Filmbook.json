{
    "id" : "page.codeberg.bjawebos.Filmbook",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "sdk-extensions" : [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command" : "filmbook",
    "finish-args" : [
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland"
    ],
    "build-options" : {
        "append-path" : "/usr/lib/sdk/rust-stable/bin",
        "env" : {
            "RUST_BACKTRACE" : "1",
            "RUST_LOG" : "filmbook=debug",
            "CARGO_NET_OFFLINE" : "true",
	    "CARGO_HOME" : "/run/build/filmbook/cargo"
        }
    },
    "modules" : [
        {
        	"name" : "filmbook",
        	"builddir" : true,
        	"buildsystem" : "meson",
        	"sources" : [
        		{
        			"type": "git",
        			"url": "https://codeberg.org/bjawebos/filmbook.git",
        			"tag": "v0.3.1",
        			"commit": "a373874a18030ec1da30daaa5b9b6fb5225b4840"
        		},
        	  "cargo-sources.json"
            ]
        }
    ]
}
